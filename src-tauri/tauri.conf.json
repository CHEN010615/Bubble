{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Bubble",
  "version": "0.1.0",
  "identifier": "com.bubble.floating",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Bubble",
        "width": 400,
        "height": 355,
        "minWidth": 60,
        "minHeight": 60,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/icon.png"
    ],
    "targets": "all"
  }
}
